# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will never be committed.

# GitHub "owner/repo" used to authenticate against the fragrance data source
TEST_USER=owner/repo-name

# GitHub personal access token with read-only access to the repository
TEST_PASS=github_pat_...

# Optional: override the dev server URL (default: http://localhost:5173)
# TEST_BASE_URL=http://localhost:5173
